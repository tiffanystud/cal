        {
            "id": "msg_j002",
            "senderId": "65f3aa11a009",
            "receiverId": "65f3aa11a003",
            "date": "2026-09-19",
            "time": "20:10",
            "content": "Ja jag vet vad du menar. Han var på AW senast också och satt och kommenterade allting. Jag bjuder inte med honom.",
